# Copy to .env and fill in. NEVER commit .env — it is gitignored.

# ---- Resource server (the MCP server) ----
PORT=3000

# Canonical resource identifier (RFC 8707). Access tokens MUST carry this exact
# value in `aud`, or verification fails. No fragment, no trailing slash drift.
MCP_RESOURCE_URL=http://localhost:3000/mcp

# Issuer of the access tokens this server accepts. Must match the `iss` claim
# and the authorization server's own metadata `issuer` value exactly.
MCP_ISSUER_URL=http://localhost:4000

# Where to fetch the issuer's signing keys.
MCP_JWKS_URI=http://localhost:4000/jwks.json

# Space-separated scopes a caller must hold to reach the tool endpoints.
MCP_REQUIRED_SCOPES=mcp:tools

# jwt    -> OAuth 2.1 bearer JWTs signed by MCP_ISSUER_URL (use this).
# static -> single shared secret in MCP_STATIC_TOKEN. Local/CI only.
MCP_AUTH_MODE=jwt

# Only read when MCP_AUTH_MODE=static. Must be >=32 chars of real entropy:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
MCP_STATIC_TOKEN=

# ---- Authorization server (mock, for local development) ----
AS_PORT=4000
AS_ISSUER_URL=http://localhost:4000

# Resource identifiers the AS is willing to mint tokens for (comma-separated).
AS_ALLOWED_RESOURCES=http://localhost:3000/mcp

# ---- Client secrets (optional) ----------------------------------------------
# Only needed for clients whose metadata declares client_secret_basic or
# client_secret_post. private_key_jwt clients need nothing here.
#
# Store scrypt HASHES, never secrets — a plaintext secret in the environment
# reaches crash dumps, `docker inspect`, and anything that logs env at startup.
# The server refuses to start if it finds a non-hash here.
#
# Generate with:  npm run hash-secret -- <client_id>
# CLIENT_SECRETS={"https://client.example/id":"scrypt$16384$8$1$...$..."}
CLIENT_SECRETS=

# ---- CIMD (Client ID Metadata Documents) ----
# Client IDs are https URLs that dereference to a JSON metadata document.
# Set to true ONLY for local development: permits http:// and loopback/private
# client_id URLs, which disables the SSRF guard. Never enable in production.
CIMD_ALLOW_INSECURE=false

# How long a fetched client metadata document stays cached, in seconds.
CIMD_CACHE_TTL_SECONDS=300
