{
  "name": "mcp-auth-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Production-shaped remote MCP server: Streamable HTTP transport + OAuth 2.1 resource server with Client ID Metadata Document (CIMD) client authentication.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:as": "tsx watch src/mock-as/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx scripts/demo-client.ts",
    "dev:demo": "tsx watch src/demo/index.ts",
    "start:demo": "node dist/demo/index.js",
    "hash-secret": "tsx scripts/hash-secret.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "jose": "^6.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
